# darkroom.toml — config for the `darkroom` CLI.
#
# Resolution order for every shared path: CLI flag → environment variable → this file.
# Drop this file at one of:
#   ./darkroom.toml                         (project-local)
#   ~/.config/darkroom/darkroom.toml        (user-global)
#
# Either flat keys (below) or a [darkroom] section table are accepted.

# Path to the SQLite catalog. Used by every subcommand. (env: DARKROOM_CATALOG)
# Optional — defaults to ~/.config/darkroom/astro_catalog.db, created on first use.
# catalog_path = "~/.config/darkroom/astro_catalog.db"

# NAS/local archive root — contains 04_Deep Sky Objects/, 00_Calibration/, etc.
# Used by `darkroom ingest`, `darkroom wbpp`, `darkroom finish`. (env: DARKROOM_ARCHIVE)
archive_path = "~/02_Astrophotography/02_Archive"

# Root directory for WBPP session symlink trees.
# Used by `darkroom wbpp`, `darkroom finish`. (env: DARKROOM_WBPP, default: ./WBPP)
wbpp_path = "~/02_Astrophotography/03_Processing/WBPP"

# Optional: equivalent section-table form. Pick one style and stick with it.
# [darkroom]
# archive_path = "~/02_Astrophotography/02_Archive"
# wbpp_path    = "~/02_Astrophotography/03_Processing/WBPP"
