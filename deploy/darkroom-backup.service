[Unit]
Description=darkroom catalog nightly backup (VACUUM INTO + rsync to NAS)
After=network-online.target

[Service]
Type=oneshot
User=claude
Group=claude
EnvironmentFile=/etc/darkroom/env
Environment=DARKROOM_CATALOG=/var/lib/darkroom/astro_catalog.db
Environment=DARKROOM_BACKUP_DEST=darkroom-backup@192.168.2.17:/volume1/backups/darkroom
Environment=DARKROOM_BACKUP_SSH_PORT=3673
ExecStart=/opt/darkroom/deploy/darkroom-backup.sh
